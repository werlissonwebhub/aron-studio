"""
routes/auth.py — Rotas de autenticacao e creditos

Endpoints:
  POST /api/auth/sync      — sincroniza usuario Firebase com banco local
  GET  /api/user/me        — retorna saldo de creditos
  POST /api/credits/refund — estorna 1 credito ao usuario
"""

from fastapi import APIRouter, Depends, HTTPException, Request
from fastapi.responses import JSONResponse
import aiosqlite

from config import DB_NAME, WELCOME_CREDITS
from models import AuthRequest, RefundRequest
from security import verify_firebase_token, verify_firebase_token_full, DEV_MODE

router = APIRouter()


@router.post("/api/auth/sync")
async def auth_sync(request: AuthRequest, http_request: Request, token_data: dict = Depends(verify_firebase_token_full)):
    print(f">>> [AUTH SYNC] Payload: {request.model_dump()}")

    # NUNCA confiar em user_id/email/email_verified vindos do corpo da requisicao —
    # sempre usar o que o proprio Firebase verificou no token (evita que alguem
    # sequestre a conta de outra pessoa so declarando um email que nao e dele).
    if not DEV_MODE and token_data["uid"] != request.user_id:
        raise HTTPException(status_code=403, detail="user_id no body nao confere com o token autenticado.")

    verified_email = request.email if DEV_MODE else token_data.get("email")
    verified_email_ok = request.email_verified if DEV_MODE else token_data.get("email_verified", False)

    if not request.user_id or len(request.user_id.strip()) < 5:
        return JSONResponse(
            status_code=400,
            content={"status": "error", "message": "user_id invalido ou ausente"}
        )

    if verified_email and not verified_email_ok:
        return JSONResponse(
            status_code=403,
            content={
                "status": "unverified",
                "message": "Verifique seu e-mail para ativar a conta.",
            },
        )

    show_welcome_modal = False

    async with aiosqlite.connect(DB_NAME) as db:
        query = "SELECT id, credits, has_received_welcome_bonus, name FROM users WHERE id = ?"
        params = [request.user_id]

        if verified_email:
            query += " OR email = ?"
            params.append(verified_email)

        async with db.execute(query, tuple(params)) as cursor:
            row = await cursor.fetchone()

            if not row:
                await db.execute(
                    "INSERT INTO users (id, email, name, credits, has_received_welcome_bonus) VALUES (?, ?, ?, ?, 1)",
                    (request.user_id, verified_email, request.display_name, WELCOME_CREDITS),
                )
                await db.commit()
                credits = WELCOME_CREDITS
                name = request.display_name
                show_welcome_modal = True
                print(f">>> [NEW USER] {request.user_id} criado.")

            elif row[0] != request.user_id:
                old_uid = row[0]
                credits = row[1]
                name = row[3] or request.display_name
                print(f">>> [RE-REGISTER] UID {old_uid} -> {request.user_id}")
                await db.execute(
                    "UPDATE users SET id = ?, name = ? WHERE id = ?",
                    (request.user_id, name, old_uid),
                )
                await db.execute(
                    "UPDATE chats SET user_id = ? WHERE user_id = ?",
                    (request.user_id, old_uid),
                )
                await db.commit()

            else:
                credits = row[1]
                name = row[3] or request.display_name
                if not row[3] and request.display_name:
                    await db.execute(
                        "UPDATE users SET name = ? WHERE id = ?",
                        (request.display_name, request.user_id),
                    )
                    await db.commit()

    return {
        "status": "success",
        "uid": request.user_id,
        "credits": credits,
        "name": name,
        "show_welcome_modal": show_welcome_modal,
    }


@router.get("/api/user/me")
async def get_user_me(user_id: str, verified_uid: str = Depends(verify_firebase_token)):
    if not DEV_MODE and verified_uid != user_id:
        raise HTTPException(status_code=403, detail="Acesso negado")
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute(
            "SELECT credits, has_received_welcome_bonus FROM users WHERE id = ?",
            (user_id,),
        ) as cursor:
            row = await cursor.fetchone()
            if not row:
                raise HTTPException(status_code=404, detail="Usuario nao encontrado")
            return {
                "credits": row[0],
                "has_received_welcome_bonus": bool(row[1]),
            }


@router.post("/api/credits/refund")
async def refund_credit(request: RefundRequest, verified_uid: str = Depends(verify_firebase_token)):
    if not DEV_MODE and verified_uid != request.user_id:
        raise HTTPException(status_code=403, detail="Acesso negado")
    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute(
            "UPDATE users SET credits = credits + 1 WHERE id = ?",
            (request.user_id,),
        )
        await db.execute(
            "INSERT INTO credit_logs (user_id, amount, reason) VALUES (?, ?, ?)",
            (request.user_id, 1, f"refund: {request.reason}"),
        )
        await db.commit()

        async with db.execute(
            "SELECT credits FROM users WHERE id = ?", (request.user_id,)
        ) as res:
            row = await res.fetchone()
            return {"status": "success", "new_balance": row[0] if row else 0}
