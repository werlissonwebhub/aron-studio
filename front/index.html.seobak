                                    data-target="47">0</span></div>
                            <div class="md-metric"><span class="md-label">Usuarios</span><span class="md-val"
                                    data-target="1284">0</span></div>
                            <div class="md-metric"><span class="md-label">Conversao</span><span class="md-val"
                                    data-target="12" data-suffix="%">0</span></div>
                        </div>
                        <div class="md-chart">
