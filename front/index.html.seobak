                            <div class="md-bar" style="--h:65%"></div>
                            <div class="md-bar" style="--h:45%"></div>
                            <div class="md-bar" style="--h:80%"></div>
                            <div class="md-bar" style="--h:55%"></div>
                            <div class="md-bar" style="--h:95%"></div>
