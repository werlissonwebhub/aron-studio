                            <path fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
                            <path fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                        <span class="text-[10px] font-black text-white uppercase tracking-[0.2em]">Google
                            Identity</span>
                    </button>
                    <button onclick="loginWithGithub()"
                        class="w-full py-3.5 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center hover:bg-white/10 transition-all group">
                        <svg class="h-4 w-4 mr-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                        <span class="text-[10px] font-black text-white uppercase tracking-[0.2em]">Github Secure</span>
                    </button>
                </div>

                <div class="relative py-2 hidden" id="divider-text">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-white/5"></div>
                    </div>
                    <div
                        class="relative flex justify-center text-[8px] uppercase tracking-[0.4em] text-zinc-700 font-black bg-[#09090b] px-2 italic">
                        Standard</div>
                </div>

                <div class="space-y-3.5" id="auth-inputs">
                    <div class="floating-group hidden overflow-hidden transition-all duration-500" id="reg-name-field">
                        <input type="text" placeholder=" " class="floating-field" id="input-name">
                        <label class="floating-label">Nome Completo</label>
                    </div>
                    <div class="floating-group">
                        <input type="email" placeholder=" " class="floating-field" id="input-email">
                        <label class="floating-label">Email de Trabalho</label>
                    </div>
                    <div class="floating-group">
                        <input type="password" placeholder=" " class="floating-field" id="input-serial">
                        <label class="floating-label">Chave Serial</label>
                    </div>
                </div>

                <div id="forgot-password-link" class="flex justify-end px-1 mt-[-8px]">
                    <button onclick="switchAuthTab('forgot')"
                        class="text-[9px] text-zinc-600 hover:text-[#34D7DD] transition-all uppercase tracking-widest font-bold">Esqueci
                        minha senha</button>
                </div>

                <button id="auth-submit-btn" onclick="handleAuthAction(event)"
                    class="w-full py-4 bg-gradient-to-r from-[#8A3FFC] to-[#34D7DD] text-white font-black text-[10px] uppercase tracking-[0.3em] rounded-xl hover:shadow-[0_0_40px_rgba(138,63,252,0.4)] transition-all active:scale-95 mt-4">
                    Autenticar
                </button>
                <p id="auth-error" class="text-[10px] text-red-500 font-bold text-center mt-2 hidden"></p>
            </div>

            <div class="text-center">
                <button onclick="toggleModal()"
                    class="text-[9px] text-zinc-800 uppercase tracking-[0.4em] hover:text-white transition-all font-black">Encerrar
                    Sessão</button>
            </div>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyD1E__qsxIBVr5R3lVR60LB5YmSH5N6cao",
            authDomain: "ia-enterprises.firebaseapp.com",
            databaseURL: "https://ia-enterprises-default-rtdb.firebaseio.com",
            projectId: "ia-enterprises",
            storageBucket: "ia-enterprises.firebasestorage.app",
            messagingSenderId: "136892318871",
            appId: "1:136892318871:web:d618a17524e39d742f55d2",
            measurementId: "G-1FG3KPREV1"
        };

        // Initialize Firebase
        const API_URL = 'http://127.0.0.1:8000';
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();

        window.loginWithGoogle = async () => {
            const provider = new firebase.auth.GoogleAuthProvider();
            try {
                const result = await auth.signInWithPopup(provider);
                await handleAuthSuccess(result.user);
            } catch (error) {
                console.error("Erro no login Google:", error);
                alert("Falha ao autenticar com Google.");
            }
        };

        window.loginWithGithub = async () => {
            const provider = new firebase.auth.GithubAuthProvider();
            try {
                const result = await auth.signInWithPopup(provider);
                await handleAuthSuccess(result.user);
            } catch (error) {
                console.error("Erro no login Github:", error);
                alert("Falha ao autenticar com Github.");
            }
        };

        async function handleAuthSuccess(user) {
            const response = await fetch('/api/auth/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid: user.uid, email: user.email })
            });
            const data = await response.json();
            localStorage.setItem('aron_user_id', user.uid);
            window.location.href = '/chat';
        }

        auth.onAuthStateChanged((user) => {
            if (user) {
                localStorage.setItem('aron_user_id', user.uid);
            }
        });

        window.handleAuthAction = async (e) => {
            if (e) e.preventDefault();
            const email = document.getElementById('input-email').value;
            const password = document.getElementById('input-serial').value;
            const errorEl = document.getElementById('auth-error');
            const submitBtn = document.getElementById('auth-submit-btn');

            const isRegister = document.getElementById('tab-register').classList.contains('active');
            const isForgot = document.getElementById('auth-title').textContent === 'Recuperar Acesso';

            if (!email || (!password && !isForgot)) {
                errorEl.textContent = "Preencha os campos obrigatórios.";
                errorEl.classList.remove('hidden', 'text-green-500');
                errorEl.classList.add('text-red-500');
                return;
            }

            errorEl.classList.add('hidden');
            submitBtn.disabled = true;

            if (isForgot) {
                submitBtn.textContent = "Enviando...";
                try {
                    await auth.sendPasswordResetEmail(email);
                    errorEl.textContent = "E-mail de recuperação enviado! Verifique sua caixa de entrada.";
                    errorEl.classList.remove('hidden', 'text-red-500');
                    errorEl.classList.add('text-green-500');
                    setTimeout(() => switchAuthTab('login'), 3000);
                } catch (error) {
                    errorEl.textContent = "Verifique o e-mail digitado.";
                    errorEl.classList.remove('hidden', 'text-green-500');
                    errorEl.classList.add('text-red-500');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Enviar Link";
                }
                return;
            }

            submitBtn.textContent = isRegister ? "Registrando..." : "Autenticando...";

            try {
                let user;
                if (isRegister) {
                    console.log(">>> [AUTH] Iniciando criação de conta para:", email);
                    const result = await auth.createUserWithEmailAndPassword(email, password);
                    user = result.user;

                    console.log(">>> [AUTH] Conta criada com sucesso no Firebase. UID:", user.uid);

                    try {
                        // Configuração para retorno após verificação
                        const actionCodeSettings = {
                            url: window.location.origin + '/chat.html',
                            handleCodeInApp: true,
                        };

                        // Tentar enviar e-mail de verificação com configurações
                        await user.sendEmailVerification(actionCodeSettings);
                        console.log(">>> [AUTH] E-mail de verificação disparado.");

                        // UI de Sucesso Elegante
                        showVerificationModal(email);
                    } catch (emailErr) {
                        console.error(">>> [AUTH] FALHA AO ENVIAR E-MAIL:", emailErr);

                        // ALERTA CRÍTICO PARA DEBUG
                        alert("ERRO NO ENVIO DE E-MAIL:\n" + emailErr.message + "\n\nVerifique se o domínio está autorizado no console do Firebase.");

                        // REMOVIDA EXCLUSÃO PREVENTIVA (Conforme pedido)
                        // await user.delete();

                        // Tentamos prosseguir para mostrar o modal de qualquer forma
                        showVerificationModal(email);
                    }
                } else {
                    const result = await auth.signInWithEmailAndPassword(email, password);
                    user = result.user;
                    await handleAuthSuccess(user);
                }
            } catch (error) {
                console.error(">>> [AUTH] ERRO:", error.code, error.message);

                if (error.code === 'auth/email-already-in-use') {
                    // FALLBACK: Tentar logar automaticamente se já existe
                    console.warn(">>> [AUTH] Usuário já existe. Tentando login automático...");
                    try {
                        const result = await auth.signInWithEmailAndPassword(email, password);
                        await handleAuthSuccess(result.user);
                        return;
                    } catch (loginErr) {
                        errorEl.textContent = "Este e-mail já está em uso e a senha está incorreta.";
                    }
                } else if (error.code === 'auth/too-many-requests') {
                    errorEl.textContent = "Muitas tentativas. Tente novamente em alguns minutos.";
                } else if (error.code === 'auth/weak-password') {
                    errorEl.textContent = "A senha é muito fraca (mínimo 6 caracteres).";
                } else {
                    errorEl.textContent = error.message;
                }
                errorEl.classList.remove('hidden', 'text-green-500');
                errorEl.classList.add('text-red-500');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = isRegister ? "Registrar" : "Autenticar";
            }
        };

        async function handleAuthSuccess(user, isFirstTime = false) {
            try {
                const response = await fetch(`${API_URL}/api/auth/sync`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ uid: user.uid, email: user.email, email_verified: user.emailVerified })
                });
                const data = await response.json();
                localStorage.setItem('aron_user_id', user.uid);

                if (isFirstTime) {
                    showVerificationModal(user.email);
                } else {
                    window.location.href = '/chat.html';
                }
            } catch (e) {
                console.error("Erro no sync:", e);
                window.location.href = '/chat.html';
            }
        }

        window.showVerificationModal = (email) => {
            const title = document.getElementById('auth-title');
            const errorEl = document.getElementById('auth-error');
            const submitBtn = document.getElementById('auth-submit-btn');

            // Novos seletores via ID para evitar erro de .space-y-3.5
            const inputFields = document.getElementById('auth-inputs');
            const socialBtns = document.getElementById('auth-social');
            const divider = document.getElementById('divider-text');
            const forgotLink = document.getElementById('forgot-password-link');
            const tabs = document.getElementById('auth-tabs');

            if (tabs) tabs.classList.add('hidden');
            if (inputFields) inputFields.classList.add('hidden');
            if (socialBtns) socialBtns.classList.add('hidden');
            if (divider) divider.classList.add('hidden');
            if (forgotLink) forgotLink.classList.add('hidden');

            title.textContent = 'Ative sua Conta';
            errorEl.innerHTML = `Enviamos um link de ativação para:<br><b class="text-[#34D7DD]">${email}</b><br><br>Verifique sua caixa de entrada e clique no link para liberar seu acesso.`;
            errorEl.classList.remove('hidden', 'text-red-500');
            errorEl.classList.add('text-green-500', 'text-center', 'text-xs', 'leading-relaxed');

            submitBtn.textContent = 'Ir para o Login';
            submitBtn.onclick = () => window.location.reload();
            submitBtn.disabled = false;
        };

        window.toggleModal = (mode = 'login') => {
            const modal = document.getElementById('auth-modal');
            const content = document.getElementById('modal-content');

            if (modal.classList.contains('opacity-0')) {
                window.switchAuthTab(mode);
                modal.classList.remove('opacity-0', 'pointer-events-none');
                setTimeout(() => {
                    content.classList.remove('scale-90', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            } else {
                content.classList.add('scale-90', 'opacity-0');
                content.classList.remove('scale-100', 'opacity-100');
                setTimeout(() => {
                    modal.classList.add('opacity-0', 'pointer-events-none');
                }, 500);
            }
        };

        window.switchAuthTab = (mode) => {
            const title = document.getElementById('auth-title');
            const submitBtn = document.getElementById('auth-submit-btn');
            const nameField = document.getElementById('reg-name-field');
            const passwordField = document.getElementById('input-serial').parentElement;
            const tabLogin = document.getElementById('tab-login');
            const tabReg = document.getElementById('tab-register');
            const errorEl = document.getElementById('auth-error');
            const forgotLink = document.getElementById('forgot-password-link');

            if (errorEl) {
                errorEl.classList.add('hidden');
                errorEl.classList.remove('text-green-500');
                errorEl.classList.add('text-red-500');
            }

            if (mode === 'register') {
                title.textContent = 'Criar Conta';
                submitBtn.textContent = 'Registrar';
                nameField.classList.remove('hidden');
                passwordField.classList.remove('hidden');
                tabReg.classList.add('active');
                tabLogin.classList.remove('active');
                forgotLink.classList.add('hidden');
            } else if (mode === 'forgot') {
                title.textContent = 'Recuperar Acesso';
                submitBtn.textContent = 'Enviar Link';
                nameField.classList.add('hidden');
                passwordField.classList.add('hidden');
                tabReg.classList.remove('active');
                tabLogin.classList.remove('active');
                forgotLink.classList.add('hidden');
            } else {
                title.textContent = 'Seja bem-vindo.';
                submitBtn.textContent = 'Autenticar';
                nameField.classList.add('hidden');
                passwordField.classList.remove('hidden');
                tabLogin.classList.add('active');
                tabReg.classList.remove('active');
                forgotLink.classList.remove('hidden');
            }
        };

        window.setVirtualText = (text) => {
            if (typeof simulateVirtualTyping === 'function') {
                simulateVirtualTyping(text);
            }
        };
    </script>

    <script>
        lucide.createIcons();

        // Reveal System
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Typewriter Effect Logic
        const typeTargets = document.querySelectorAll('[data-autotype]');

        async function runTypewriter(el) {
            const text = el.getAttribute('data-autotype');
            el.textContent = '';
            if (!text) return;
            for (let i = 0; i <= text.length; i++) {
                el.textContent = text.substring(0, i);
                await new Promise(r => setTimeout(r, 30));
            }
        }

        function startTypewriterCycle() {
            typeTargets.forEach(el => runTypewriter(el));
            setTimeout(startTypewriterCycle, 10000); // 10s loop
        }
        startTypewriterCycle();

        // Virtual Showcase Input Typing Logic
        const virtualInputPhrases = [
            'Um dashboard de vendas com gráficos em ciano e roxo...',
            'Landing page estilo Apple para um novo fone Bluetooth...',
            'Aplicativo web financeiro com dashboard interativo...'
        ];
        let virtualTypingIdx = 0;
        let isVirtualTyping = false;
        let typingTimeout;

        async function simulateVirtualTyping(specificText = null) {
            if (isVirtualTyping && !specificText) return;
            isVirtualTyping = true;
            clearTimeout(typingTimeout);

            const targetEl = document.getElementById('virtual-typing-text');
            if (!targetEl) return;

            const textToType = specificText || virtualInputPhrases[virtualTypingIdx];

            // Delete current text quickly
            let currentText = targetEl.textContent;
            for (let i = currentText.length; i >= 0; i--) {
                targetEl.textContent = currentText.substring(0, i);
                await new Promise(r => setTimeout(r, 15));
            }

            await new Promise(r => setTimeout(r, 200));

            // Type new text randomly
            for (let i = 0; i <= textToType.length; i++) {
                targetEl.textContent = textToType.substring(0, i);
                await new Promise(r => setTimeout(r, 30 + Math.random() * 40));
            }

            if (!specificText) {
                virtualTypingIdx = (virtualTypingIdx + 1) % virtualInputPhrases.length;
                typingTimeout = setTimeout(() => {
                    isVirtualTyping = false;
                    simulateVirtualTyping();
                }, 4000);
            } else {
                isVirtualTyping = false;
                // restarts auto loop after 6s of specific text
                typingTimeout = setTimeout(() => {
                    simulateVirtualTyping();
                }, 6000);
            }
        }

        // Start virtual typing loop
        setTimeout(() => simulateVirtualTyping(), 1000);

        // Stagger Scroll Logic for Showcase
        const staggerObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    staggerObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        document.querySelectorAll('.stagger-slide-up').forEach(el => staggerObserver.observe(el));

        // Topbar Scroll Detection — Neon line activation
        const topbar = document.getElementById('topbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                topbar.classList.add('scrolled');
            } else {
                topbar.classList.remove('scrolled');
            }
        }, { passive: true });

        // Dot Grid Background (Manus-style)
        class DotGrid {
            constructor(canvasId) {
                this.canvas = document.getElementById(canvasId);
                if (!this.canvas) return;
                this.ctx = this.canvas.getContext('2d');
                this.dots = [];
                this.spacing = 30; // Base spacing between dots in pixels
                this.dotRadius = 1.5; // Base radius of each dot
                this.mouse = { x: -1000, y: -1000, tx: -1000, ty: -1000 };
                this.hoverRadius = 160; // Influence area of the mouse cursor
                this.time = 0;

                this.init();
                this.bindEvents();
                this.animate();
            }

            init() {
                this.resize();
            }

            resize() {
                const parent = this.canvas.parentElement;
                if (!parent) return;
                const width = parent.clientWidth;
                const height = parent.clientHeight;

                const dpr = window.devicePixelRatio || 1;
                this.canvas.width = width * dpr;
                this.canvas.height = height * dpr;
                this.canvas.style.width = `${width}px`;
                this.canvas.style.height = `${height}px`;
                this.ctx.scale(dpr, dpr);

                this.width = width;
                this.height = height;

                if (width < 768) {
                    this.spacing = 24;
                    this.hoverRadius = 120;
                } else {
                    this.spacing = 30;
                    this.hoverRadius = 180;
                }

                this.cols = Math.ceil(this.width / this.spacing) + 1;
                this.rows = Math.ceil(this.height / this.spacing) + 1;
            }

            bindEvents() {
                const parent = this.canvas.parentElement;
                if (!parent) return;

                const updateMouse = (e) => {
                    const rect = parent.getBoundingClientRect();
                    this.mouse.tx = e.clientX - rect.left;
                    this.mouse.ty = e.clientY - rect.top;
                };

                const leaveMouse = () => {
                    this.mouse.tx = -1000;
                    this.mouse.ty = -1000;
                };

                parent.addEventListener('mousemove', updateMouse, { passive: true });
                parent.addEventListener('mouseleave', leaveMouse, { passive: true });

                window.addEventListener('resize', () => this.resize(), { passive: true });
            }

            animate() {
                this.time += 0.015;

                // Lerp mouse coordinates for smooth lag-less transitions
                if (this.mouse.tx === -1000) {
                    this.mouse.x += (-1000 - this.mouse.x) * 0.08;
                    this.mouse.y += (-1000 - this.mouse.y) * 0.08;
                    if (Math.abs(this.mouse.x + 1000) < 0.1) {
                        this.mouse.x = -1000;
                        this.mouse.y = -1000;
                    }
                } else {
                    if (this.mouse.x === -1000) {
                        this.mouse.x = this.mouse.tx;
                        this.mouse.y = this.mouse.ty;
                    } else {
                        this.mouse.x += (this.mouse.tx - this.mouse.x) * 0.15;
                        this.mouse.y += (this.mouse.ty - this.mouse.y) * 0.15;
                    }
                }

                this.draw();
                requestAnimationFrame(() => this.animate());
            }

            draw() {
                this.ctx.clearRect(0, 0, this.width, this.height);

                // Draw dynamic radial background glow centered at the mouse coordinates
                if (this.mouse.x !== -1000) {
                    const glow = this.ctx.createRadialGradient(
                        this.mouse.x, this.mouse.y, 0,
                        this.mouse.x, this.mouse.y, this.hoverRadius
                    );
                    // Glowing purple to teal/cyan with transparency
                    glow.addColorStop(0, 'rgba(138, 63, 252, 0.12)');
                    glow.addColorStop(0.5, 'rgba(52, 215, 221, 0.04)');
                    glow.addColorStop(1, 'rgba(0, 0, 0, 0)');

                    this.ctx.fillStyle = glow;
                    this.ctx.beginPath();
                    this.ctx.arc(this.mouse.x, this.mouse.y, this.hoverRadius, 0, Math.PI * 2);
                    this.ctx.fill();
                }

                const offsetX = (this.width % this.spacing) / 2;
                const offsetY = (this.height % this.spacing) / 2;

                for (let c = 0; c < this.cols; c++) {
                    for (let r = 0; r < this.rows; r++) {
                        const x = c * this.spacing + offsetX;
                        const y = r * this.spacing + offsetY;

                        let dist = 99999;
                        if (this.mouse.x !== -1000) {
                            const dx = x - this.mouse.x;
                            const dy = y - this.mouse.y;
                            dist = Math.sqrt(dx * dx + dy * dy);
                        }

                        let mouseIntensity = 0;
                        if (dist < this.hoverRadius) {
                            mouseIntensity = Math.pow(1 - dist / this.hoverRadius, 1.8);
                        }

                        // Subtle ambient wave ripple that moves slowly diagonally
                        const wave = Math.sin(x * 0.005 - y * 0.003 + this.time) * Math.cos(y * 0.005 + this.time * 0.8) * 0.5 + 0.5;
                        const ambientIntensity = wave * 0.15;

                        const totalIntensity = Math.min(1.0, mouseIntensity + ambientIntensity);

                        // Static baseline dots vs glowing active dots
                        if (totalIntensity > 0.02) {
                            // Compute dynamic purple (138, 63, 252) to blue/cyan (52, 215, 221) transition
                            // based on time and position
                            const colorPhase = (x / this.width * 0.5 + y / this.height * 0.5 + this.time * 0.2) % 1;

                            let rColor, gColor, bColor;
                            if (colorPhase < 0.5) {
                                const factor = colorPhase * 2;
                                rColor = Math.round(138 + (52 - 138) * factor);
                                gColor = Math.round(63 + (215 - 63) * factor);
                                bColor = Math.round(252 + (221 - 252) * factor);
                            } else {
                                const factor = (colorPhase - 0.5) * 2;
                                rColor = Math.round(52 + (138 - 52) * factor);
                                gColor = Math.round(215 + (63 - 215) * factor);
                                bColor = Math.round(221 + (252 - 221) * factor);
                            }

                            // Base gray color for non-lit dots: #333333 -> RGB (51, 51, 51)
                            const baseR = 51, baseG = 51, baseB = 51;

                            const finalR = Math.round(baseR + (rColor - baseR) * totalIntensity);
                            const finalG = Math.round(baseG + (gColor - baseG) * totalIntensity);
                            const finalB = Math.round(baseB + (bColor - baseB) * totalIntensity);

                            const alpha = 0.15 + 0.8 * totalIntensity;
                            const radius = this.dotRadius + 1.2 * totalIntensity;

                            this.ctx.fillStyle = `rgba(${finalR}, ${finalG}, ${finalB}, ${alpha})`;
                            this.ctx.beginPath();
                            this.ctx.arc(x, y, radius, 0, Math.PI * 2);
                            this.ctx.fill();
                        } else {
                            // High-performance static paths
                            this.ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
                            this.ctx.beginPath();
                            this.ctx.arc(x, y, this.dotRadius, 0, Math.PI * 2);
                            this.ctx.fill();
                        }
                    }
                }
            }
        }

        // Initialize background
        new DotGrid('dot-grid-canvas');
    </script>

    <script>
        (function () {
            const canvas = document.getElementById('globe-canvas');
            if (!canvas || !window.THREE) return;
            let width = canvas.clientWidth, height = canvas.clientHeight;
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(40, width / height, 0.1, 1000);
            camera.position.z = 370;
            const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
            renderer.setSize(width, height, false);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            const globe = new THREE.Group(); scene.add(globe);
            const RADIUS = 100;
            function fibonacciSphere(samples, radius) {
                const pts = []; const phi = Math.PI * (3 - Math.sqrt(5));
                for (let i = 0; i < samples; i++) {
                    const y = 1 - (i / (samples - 1)) * 2; const r = Math.sqrt(1 - y * y); const theta = phi * i;
                    pts.push(new THREE.Vector3(Math.cos(theta) * r * radius, y * radius, Math.sin(theta) * r * radius));
                } return pts;
            }
            const dotGeo = new THREE.BufferGeometry().setFromPoints(fibonacciSphere(2600, RADIUS));
            globe.add(new THREE.Points(dotGeo, new THREE.PointsMaterial({ color: 0x4f5bd5, size: 1.4, transparent: true, opacity: 0.55, sizeAttenuation: true })));
            globe.add(new THREE.Mesh(new THREE.SphereGeometry(RADIUS * 0.99, 28, 28), new THREE.MeshBasicMaterial({ color: 0x6366f1, wireframe: true, transparent: true, opacity: 0.06 })));
            globe.add(new THREE.Mesh(new THREE.SphereGeometry(RADIUS * 0.96, 32, 32), new THREE.MeshBasicMaterial({ color: 0x0a0a1f, transparent: true, opacity: 0.85 })));
            function latLong(lat, lon, radius) {
                const phi = (90 - lat) * Math.PI / 180, theta = (lon + 180) * Math.PI / 180;
                return new THREE.Vector3(-radius * Math.sin(phi) * Math.cos(theta), radius * Math.cos(phi), radius * Math.sin(phi) * Math.sin(theta));
            }
            const cities = [[-23.55, -46.63], [-22.91, -43.17], [-15.79, -47.88], [-3.73, -38.52], [-12.97, -38.50], [-8.05, -34.88], [-19.92, -43.94], [-30.03, -51.23], [-3.12, -60.02], [-16.68, -49.25], [-25.43, -49.27], [-27.59, -48.55]];
            const markers = [];
            cities.forEach(([lat, lon]) => {
                const pos = latLong(lat, lon, RADIUS * 1.02);
                const m = new THREE.Mesh(new THREE.SphereGeometry(1.8, 12, 12), new THREE.MeshBasicMaterial({ color: 0x34D7DD }));
                m.position.copy(pos); globe.add(m);
                const ring = new THREE.Mesh(new THREE.RingGeometry(2.5, 3.5, 16), new THREE.MeshBasicMaterial({ color: 0x34D7DD, transparent: true, opacity: 0.5, side: THREE.DoubleSide }));
                ring.position.copy(pos); ring.lookAt(0, 0, 0); globe.add(ring);
                markers.push({ mesh: m, ring: ring, phase: Math.random() * Math.PI * 2 });
            });
            const SP = latLong(-23.55, -46.63, RADIUS);
            function makeArc(start, end) {
                const mid = start.clone().add(end).multiplyScalar(0.5).normalize().multiplyScalar(RADIUS * 1.35);
                const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
                return new THREE.Line(new THREE.BufferGeometry().setFromPoints(curve.getPoints(40)), new THREE.LineBasicMaterial({ color: 0x818cf8, transparent: true, opacity: 0.35 }));
            }
            [[-3.73, -38.52], [-8.05, -34.88], [-30.03, -51.23], [-3.12, -60.02], [-15.79, -47.88]].forEach(([lat, lon]) => globe.add(makeArc(SP, latLong(lat, lon, RADIUS))));
            globe.rotation.x = 0.35; globe.rotation.y = -1.0;
            const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            let t = 0;
            function animate() {
                requestAnimationFrame(animate); t += 0.016;
                if (!reduceMotion) globe.rotation.y += 0.0022;
                markers.forEach((mk) => {
                    mk.mesh.scale.setScalar(1 + Math.sin(t * 2 + mk.phase) * 0.35);
                    mk.ring.scale.setScalar(1 + (Math.sin(t * 2 + mk.phase) * 0.5 + 0.5) * 1.2);
                    mk.ring.material.opacity = 0.5 * (1 - (Math.sin(t * 2 + mk.phase) * 0.5 + 0.5));
                });
                renderer.render(scene, camera);
            }
            animate();
            function onResize() {
                width = canvas.clientWidth; height = canvas.clientHeight;
                camera.aspect = width / height; camera.updateProjectionMatrix();
                renderer.setSize(width, height, false);
            }
            window.addEventListener('resize', onResize); setTimeout(onResize, 100);
        })();
    </script>
    <script>
        (function () {
            const cards = document.querySelectorAll('[data-tilt]');
            const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (reduce) return;
            cards.forEach(card => {
                const glare = card.querySelector('.tilt-glare');
                card.addEventListener('mousemove', e => {
                    const r = card.getBoundingClientRect();
                    const x = e.clientX - r.left, y = e.clientY - r.top;
                    const rotX = ((y - r.height / 2) / (r.height / 2)) * -9;
                    const rotY = ((x - r.width / 2) / (r.width / 2)) * 9;
                    card.style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateZ(0)`;
                    if (glare) { glare.style.setProperty('--mx', (x / r.width * 100) + '%'); glare.style.setProperty('--my', (y / r.height * 100) + '%'); }
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) translateZ(0)';
                });
            });
        })();
    </script>

    <script>
        (function () {
            var c = document.getElementById('pills-mobile');
            if (!c) return;
            var ps = c.querySelectorAll('button'), idx = 0, paused = false;
            c.addEventListener('touchstart', function () { paused = true; setTimeout(function () { paused = false; }, 3000); }, { passive: true });
            setInterval(function () {
                if (paused) return;
                idx = (idx + 1) % ps.length;
                var p = ps[idx];
                var target = p.offsetLeft - (c.clientWidth - p.offsetWidth) / 2;
                target = Math.max(0, Math.min(target, c.scrollWidth - c.clientWidth));
                c.scrollTo({ left: target, behavior: 'smooth' });
            }, 2500);
        })();
    </script>
</body>

</html>