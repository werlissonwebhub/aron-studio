                            <div class="mg-cell" data-i="1"></div>
                            <div class="mg-cell" data-i="2"></div>
                            <div class="mg-cell" data-i="3"></div>
                            <div class="mg-cell" data-i="4"></div>
                            <div class="mg-cell" data-i="5"></div>
                            <div class="mg-cell" data-i="6"></div>
