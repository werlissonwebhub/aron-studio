    <!-- AUTH MODAL v7 (Enterprise Style) -->
    <div id="auth-modal"
        class="fixed inset-0 z-[200] bg-black/60 backdrop-blur-3xl flex items-center justify-center p-6 opacity-0 pointer-events-none transition-all duration-500">
        <div class="w-full max-w-sm glass rounded-[32px] p-10 space-y-8 scale-90 opacity-0 transition-all duration-500 shadow-[0_50px_100px_rgba(0,0,0,0.9)]"
            id="modal-content">
            <div class="text-center space-y-6" id="auth-tabs">
                <div class="flex justify-center space-x-8 pt-4">
                    <span id="tab-login" class="auth-tab active" onclick="switchAuthTab('login')">Entrar</span>
                    <span id="tab-register" class="auth-tab" onclick="switchAuthTab('register')">Cadastrar-se</span>
                </div>
            </div>

            <div class="space-y-4">
                <h3 id="auth-title" class="text-2xl font-black text-white text-center">Seja bem-vindo.</h3>

                <div class="space-y-3" id="auth-social">
                    <button onclick="loginWithGoogle()"
                        class="w-full py-3.5 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center hover:bg-white/10 transition-all group">
                        <svg class="h-4 w-4 mr-3" viewBox="0 0 24 24">
                            <path fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
