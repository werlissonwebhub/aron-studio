<!DOCTYPE html>
<html lang="pt-BR" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aron elite v1 — Crie sites e apps profissionais com IA em segundos</title>
    <meta name="description"
        content="O Aron Studio usa Inteligência Artificial para criar sites e apps profissionais em segundos. Descreva o que você precisa e a IA constrói para você.">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#09090b">

    <!-- Open Graph (WhatsApp, Instagram, LinkedIn, Facebook) -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://aronstudio.com.br/">
    <meta property="og:title" content="Aron Studio — Crie sites e apps com IA em segundos">
    <meta property="og:description"
        content="Descreva o site que você precisa e a IA constrói para você. Rápido, profissional e sem precisar saber programar.">
    <meta property="og:image" content="https://aronstudio.com.br/img/hero.png">
    <meta property="og:locale" content="pt_BR">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Aron elite v1 — Crie sites com IA em segundos">
    <meta name="twitter:description" content="Descreva o site que você precisa e a IA constrói para você.">
    <meta name="twitter:image" content="https://aronstudio.com.br/img/hero.png">

    <!-- Favicon -->
    <link rel="icon" href="img/studio-aron.png" type="image/png">
    <link rel="apple-touch-icon" href="img/studio-aron.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #09090b;
            --accent: #8A3FFC;
            /* Roxo Neon */
            --accent-light: #34D7DD;
            /* Ciano Neon */
            --text-muted: #A1A1AA;
            /* Texto Muted */
        }

        @property --glow-angle {
            syntax: '<angle>';
            initial-value: 0deg;
            inherits: false;
        }

        body {
            background: var(--bg);
            color: #fafafa;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- ATMOSPHERE --- */
        #dot-grid-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        .aurora-container {
            position: fixed;
            inset: 0;
            z-index: -1;
            pointer-events: none;
            opacity: 0.3;
            filter: blur(120px);
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            animation: drift 40s infinite alternate ease-in-out;
        }

        @keyframes drift {
            0% {
                transform: translate(0, 0) scale(1);
            }

            50% {
                transform: translate(15vw, 8vh) scale(1.1);
            }

            100% {
                transform: translate(-8vw, 15vh) scale(0.9);
            }
        }

        /* --- INFINITE SCROLL CAROUSEL --- */
        .carousel-view {
            overflow: hidden;
            width: 100%;
            mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
            position: relative;
        }

        .carousel-track {
            display: flex;
            flex-direction: row;
            width: max-content;
            animation: scroll-antigravity 35s linear infinite;
        }

        .carousel-track:hover {
            animation-play-state: paused;
        }

        @keyframes scroll-antigravity {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        .carousel-card {
            flex-shrink: 0;
            width: 300px;
            height: 200px;
            margin: 0 16px;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.05);
            background: #000;
            transition: all 0.5s ease;
        }

        .carousel-card img {
            width: 300px;
            height: 200px;
            object-fit: cover;
        }

        .carousel-card:hover {
            border-color: var(--accent);
            transform: scale(1.03);
        }

        /* --- CONIC BORDER GLOW --- */
        .glow-border {
            position: relative;
            z-index: 0;
            border-radius: 24px;
            background: #09090b;
        }

        .glow-border::before {
            content: "";
            position: absolute;
            inset: -1.5px;
            z-index: -1;
            border-radius: 24px;
            background: conic-gradient(from var(--glow-angle), transparent 20%, var(--accent) 50%, var(--accent-light) 80%, transparent 100%);
            animation: rotate-glow 6s linear infinite;
        }

        @keyframes rotate-glow {
            from {
                --glow-angle: 0deg;
            }

            to {
                --glow-angle: 360deg;
            }
        }

        /* --- FEATURE CARDS AAA --- */
        .feature-card {
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .feature-card:hover {
            transform: translateY(-5px) scale(1.02);
        }

        /* Icon Gradient Utility */
        .icon-gradient {
            background: linear-gradient(135deg, var(--accent), var(--accent-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        /* UI COMPONENTS */
        .glass {
            background: rgba(15, 15, 20, 0.4);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .logo-glow {
            filter: drop-shadow(0 0 20px rgba(168, 85, 247, 0.3));
        }

        /* Floating Labels & Inputs */
        .floating-group {
            position: relative;
            width: 100%;
        }

        .floating-field {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            /* Transparent Input */
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 20px 16px 8px;
            color: white;
            font-size: 13px;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .floating-label {
            position: absolute;
            left: 16px;
            top: 16px;
            color: #52525b;
            font-size: 13px;
            pointer-events: none;
            transition: all 0.2s ease;
        }

        .floating-field:focus~.floating-label,
        .floating-field:not(:placeholder-shown)~.floating-label {
            top: 6px;
            font-size: 9px;
            color: var(--accent);
            text-transform: uppercase;
            font-weight: 900;
            letter-spacing: 0.1em;
        }

        .floating-field:focus {
            border-color: rgba(138, 63, 252, 0.5);
            box-shadow: 0 0 15px rgba(138, 63, 252, 0.1);
        }

        /* Auth Tabs */
        .auth-tab {
            font-size: 10px;
            font-weight: 800;
            color: #52525b;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            cursor: pointer;
            padding-bottom: 8px;
            border-bottom: 2px solid transparent;
            transition: all 0.3s;
        }

        .auth-tab.active {
            color: white;
            border-color: var(--accent);
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-thumb {
            background: #27272a;
            border-radius: 10px;
        }

        /* --- TOPBAR PREMIUM --- */
        .topbar {
            background: rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05);
            border: none;
            position: relative;
            overflow: hidden;
        }

        .topbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, var(--accent) 30%, var(--accent-light) 70%, transparent 100%);
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .topbar.scrolled::after {
            opacity: 1;
        }

        .nav-link {
            position: relative;
            padding: 6px 12px;
            border-radius: 9999px;
            color: #71717a;
            transition: color 0.3s ease-in-out;
        }

        .nav-link::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 9999px;
            background: rgba(255, 255, 255, 0.05);
            opacity: 0;
            transform: scale(0.85);
            transition: all 0.3s ease-in-out;
        }

        .nav-link:hover::before {
            opacity: 1;
            transform: scale(1);
        }

        .nav-link:hover {
            color: #34D7DD;
        }

        .join-btn {
            transition: all 0.3s ease;
        }

        .join-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.15);
        }

        /* --- HERO BUTTONS PREMIUM --- */
        @property --btn-beam {
            syntax: '<angle>';
            initial-value: 0deg;
            inherits: false;
        }

        .btn-workspace {
            position: relative;
            padding: 14px 32px;
            background: linear-gradient(135deg, #34D7DD 0%, #8A3FFC 100%);
            color: white;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            border-radius: 14px;
            border: none;
            cursor: pointer;
            overflow: hidden;
            z-index: 0;
            transition: all 0.3s ease-in-out;
        }

        .btn-workspace::before {
            content: '';
            position: absolute;
            inset: -2px;
            z-index: -2;
            border-radius: 16px;
            background: conic-gradient(from var(--btn-beam), transparent 20%, #34D7DD 40%, #8A3FFC 60%, transparent 80%);
            animation: btn-beam-spin 3s linear infinite;
        }

        .btn-workspace::after {
            content: '';
            position: absolute;
            inset: 2px;
            z-index: -1;
            border-radius: 12px;
            background: linear-gradient(135deg, #34D7DD 0%, #8A3FFC 100%);
        }

        @keyframes btn-beam-spin {
            from {
                --btn-beam: 0deg;
            }

            to {
                --btn-beam: 360deg;
            }
        }

        .btn-workspace:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(52, 215, 221, 0.5), 0 0 50px rgba(138, 63, 252, 0.2);
        }

        .btn-workspace:active {
            transform: translateY(0) scale(0.97);
        }

        .btn-docs {
            padding: 14px 32px;
            background: transparent;
            color: rgba(255, 255, 255, 0.7);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            transition: all 0.3s ease-in-out;
        }

        .btn-docs:hover {
            color: white;
            border-color: #8A3FFC;
            background: rgba(139, 92, 246, 0.08);
            box-shadow: inset 0 0 12px rgba(138, 63, 252, 0.2), 0 0 15px rgba(138, 63, 252, 0.15);
            transform: translateY(-2px);
        }

        .btn-docs:active {
            transform: translateY(0) scale(0.97);
        }

        /* --- VIRTUAL INPUT --- */
        .virtual-input-container {
            background: rgba(15, 15, 20, 0.6);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(138, 63, 252, 0.05);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .virtual-input-container::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 20px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(138, 63, 252, 0.5), rgba(52, 215, 221, 0.5));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }

        .cursor-blink {
            display: inline-block;
            width: 2px;
            height: 1.2em;
            background-color: #34D7DD;
            vertical-align: middle;
            animation: blink 1s step-end infinite;
            margin-left: 2px;
        }

        @keyframes blink {
            50% {
                opacity: 0;
            }
        }

        .tag-pill {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #A1A1AA;
            padding: 6px 14px;
            border-radius: 12px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            outline: none;
        }

        .tag-pill:hover {
            background: rgba(138, 63, 252, 0.1);
            border-color: rgba(138, 63, 252, 0.4);
            color: white;
            box-shadow: 0 0 10px rgba(138, 63, 252, 0.2);
            transform: translateY(-2px);
        }

        /* --- SHOWCASE GRID --- */
        .showcase-grid {
            display: grid;
            gap: 2rem;
        }

        .showcase-card {
            background: #09090b;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            overflow: hidden;
            position: relative;
            transform-style: preserve-3d;
            transform: perspective(1000px);
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
        }

        .showcase-card::before {
            content: '';
            position: absolute;
            inset: -20px;
            background: radial-gradient(circle at 50% 50%, rgba(138, 63, 252, 0.15), transparent 60%);
            opacity: 0;
            transition: opacity 0.5s;
            z-index: -1;
            pointer-events: none;
        }

        .showcase-card:hover {
            transform: perspective(1000px) translateY(-10px) rotateX(2deg) rotateY(-2deg) scale(1.02);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(52, 215, 221, 0.15);
            border-color: rgba(52, 215, 221, 0.3);
        }

        .showcase-card:hover::before {
            opacity: 1;
        }

        .showcase-img-wrapper {
            width: 100%;
            height: 240px;
            overflow: hidden;
            position: relative;
        }

        .showcase-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .showcase-card:hover .showcase-img {
            transform: scale(1.08);
        }

        .showcase-info {
            padding: 24px;
            background: linear-gradient(to top, rgba(9, 9, 11, 1) 0%, rgba(9, 9, 11, 0.8) 100%);
            position: relative;
            z-index: 2;
        }

        .stagger-slide-up {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .stagger-slide-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .prospect-section {
            position: relative;
            padding: 120px 24px;
            overflow: hidden;
            background:
                radial-gradient(ellipse 80% 50% at 70% 50%, rgb(9, 9, 11), transparent 70%),
                radial-gradient(ellipse 60% 40% at 20% 30%, rgb(9, 9, 11), transparent 70%),
                #09090b;
        }

        .prospect-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            position: relative;
            z-index: 2;
        }

        .prospect-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgb(0, 0, 0);
            border: 1px solid rgb(0, 0, 0);
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.15em;
            color: #000000;
            text-transform: uppercase;
            margin-bottom: 24px;
        }

        .prospect-eyebrow .pulse {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #34D7DD;
            box-shadow: 0 0 8px #34D7DD;
            animation: pulseDot 1.6s ease-in-out infinite;
        }

        @keyframes pulseDot {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.4;
                transform: scale(1.4);
            }
        }

        .prospect-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: clamp(10px, 4vw, 30px);
            font-weight: 800;
            line-height: 1.08;
            letter-spacing: -0.02em;
            margin-bottom: 20px;
            color: #f1f5f9;
        }

        .prospect-title .grad {
            background: linear-gradient(120deg, #7206ca, #34D7DD);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .prospect-desc {
            font-size: 16px;
            line-height: 1.7;
            color: rgba(241, 245, 249, 0.6);
            margin-bottom: 32px;
            max-width: 480px;
        }

        .prospect-features {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 36px;
        }

        .prospect-feature {
            display: flex;
            align-items: flex-start;
            gap: 14px;
        }

        .prospect-feature-icon {
            width: 36px;
            height: 36px;
            flex-shrink: 0;
            border-radius: 10px;
            background: rgba(99, 102, 241, 0.12);
            border: 1px solid rgba(99, 102, 241, 0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #818cf8;
        }

        .prospect-feature-icon svg {
            width: 17px;
            height: 17px;
        }

        .prospect-feature-text h4 {
            font-size: 14px;
            font-weight: 600;
            color: #6c08be;
            margin-bottom: 2px;
        }

        .prospect-feature-text p {
            font-size: 13px;
            color: rgba(104, 164, 224, 0.979);
            line-height: 1.5;
        }

        .prospect-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 8px 30px rgba(99, 102, 241, 0.3);
        }

        .prospect-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(99, 102, 241, 0.45);
        }

        .prospect-cta svg {
            width: 18px;
            height: 18px;
            transition: transform 0.3s;
        }

        .prospect-cta:hover svg {
            transform: translateX(4px);
        }

        .prospect-globe-wrap {
            position: relative;
            width: 100%;
            aspect-ratio: 1;
            max-width: 400px;
            margin: 0 auto;
        }

        .prospect-globe-glow {
            position: absolute;
            inset: 10%;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.25), transparent 65%);
            filter: blur(40px);
            pointer-events: none;
        }

        #globe-canvas {
            position: relative;
            width: 100%;
            height: 100%;
            z-index: 2;
        }

        .globe-chip {
            position: absolute;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            background: rgba(13, 13, 22, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(99, 102, 241, 0.25);
            border-radius: 12px;
            font-size: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
            animation: floatChip 4s ease-in-out infinite;
        }

        .globe-chip .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .globe-chip .label {
            color: rgba(241, 245, 249, 0.5);
            font-size: 10px;
        }

        .globe-chip .val {
            color: #f1f5f9;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
        }

        .chip-1 {
            top: 12%;
            left: -4%;
            animation-delay: 0s;
        }

        .chip-2 {
            top: 44%;
            right: -8%;
            animation-delay: 1.3s;
        }

        .chip-3 {
            bottom: 14%;
            left: 2%;
            animation-delay: 2.6s;
        }

        @keyframes floatChip {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        @media (max-width: 880px) {
            .prospect-section {
                padding: 80px 20px;
            }

            .prospect-container {
                grid-template-columns: 1fr;
                gap: 48px;
            }

            .prospect-globe-wrap {
                max-width: 380px;
                order: -1;
            }

            .prospect-desc {
                max-width: 100%;
            }

            .chip-1 {
                left: 0;
            }

            .chip-2 {
                right: 0;
            }
        }

        @media (prefers-reduced-motion: reduce) {

            .globe-chip,
            .prospect-eyebrow .pulse {
                animation: none;
            }
        }

        .gallery-img {
            width: 300px;
            height: 190px;
            object-fit: cover;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            flex-shrink: 0;
            transition: transform 0.3s, border-color 0.3s;
            cursor: pointer;
        }

        .gallery-img:hover {
            transform: scale(1.04);
            border-color: rgba(179, 73, 245, 0.5);
            box-shadow: 0 0 30px rgba(179, 73, 245, 0.2);
        }

        .gallery-track {
            display: flex;
            gap: 20px;
            width: max-content;
        }

        .gallery-track-1 {
            animation: gallery-left 35s linear infinite;
        }

        .gallery-track-2 {
            animation: gallery-right 35s linear infinite;
        }

        @keyframes gallery-left {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        @keyframes gallery-right {
            from {
                transform: translateX(-50%);
            }

            to {
                transform: translateX(0);
            }
        }

        .gallery-fade-l {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 120px;
            background: linear-gradient(to right, #09090b, transparent);
            z-index: 2;
            pointer-events: none;
        }

        .gallery-fade-r {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            width: 120px;
            background: linear-gradient(to left, #09090b, transparent);
            z-index: 2;
            pointer-events: none;
        }

        .faq-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            cursor: pointer;
            transition: border-color .3s;
            overflow: hidden;
        }

        .faq-item:hover {
            border-color: rgba(52, 215, 221, 0.3);
        }

        .faq-q {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 20px 24px;
            font-weight: 600;
            color: #fff;
            font-size: 16px;
        }

        .faq-chev {
            flex-shrink: 0;
            color: rgba(255, 255, 255, 0.4);
            transition: transform .35s;
        }

        .faq-item.open .faq-chev {
            transform: rotate(180deg);
            color: #34D7DD;
        }

        .faq-a {
            max-height: 0;
            overflow: hidden;
            padding: 0 24px;
            color: rgba(255, 255, 255, 0.55);
            font-size: 14.5px;
            line-height: 1.7;
            transition: max-height .4s ease, padding .4s ease;
        }

        .faq-item.open .faq-a {
            max-height: 220px;
            padding: 0 24px 22px;
        }

        /* === Prospeccao lado esquerdo repaginado === */
        .prospect-text {
            position: relative;
            z-index: 2;
        }

        .np-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #34D7DD;
            margin-bottom: 22px;
            padding: 6px 14px;
            border: 1px solid rgba(52, 215, 221, 0.25);
            border-radius: 100px;
            background: rgba(52, 215, 221, 0.05);
        }

        .np-pulse {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #34D7DD;
            box-shadow: 0 0 8px #34D7DD;
            animation: npPulse 1.6s ease-in-out infinite;
        }

        @keyframes npPulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.4;
                transform: scale(1.4);
            }
        }

        .np-title {
            font-family: 'Plus Jakarta Sans', 'Space Grotesk', sans-serif;
            font-size: clamp(1.8rem, 3.5vw, 2.6rem);
            font-weight: 800;
            line-height: 1.12;
            letter-spacing: -0.02em;
            color: #f1f5f9;
            margin-bottom: 18px;
        }

        .np-grad {
            background: linear-gradient(120deg, #8A3FFC, #34D7DD);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .np-desc {
            font-size: 1rem;
            line-height: 1.7;
            color: rgba(241, 245, 249, 0.55);
            margin-bottom: 34px;
            max-width: 460px;
        }

        .np-features {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .np-feat {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1px solid transparent;
            transition: background 0.3s, border-color 0.3s, transform 0.3s;
        }

        .np-feat:hover {
            background: rgba(255, 255, 255, 0.03);
            border-color: rgba(255, 255, 255, 0.08);
            transform: translateX(4px);
        }

        .np-icon {
            width: 42px;
            height: 42px;
            flex-shrink: 0;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(138, 63, 252, 0.15), rgba(52, 215, 221, 0.1));
            border: 1px solid rgba(138, 63, 252, 0.25);
            color: #a78bfa;
            transition: color 0.3s, box-shadow 0.3s;
        }

        .np-feat:hover .np-icon {
            color: #34D7DD;
            box-shadow: 0 0 20px -4px rgba(52, 215, 221, 0.4);
        }

        .np-icon svg {
            width: 20px;
            height: 20px;
        }

        .np-feat-txt h4 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.98rem;
            font-weight: 600;
            color: #f1f5f9;
            margin: 0 0 4px 0;
        }

        .np-feat-txt p {
            font-size: 0.86rem;
            line-height: 1.55;
            color: rgba(241, 245, 249, 0.5);
            margin: 0;
        }

        @media (max-width: 900px) {
            .np-title {
                font-size: 1.6rem;
            }

            .np-feat {
                padding: 12px;
            }
        }
    </style>
    <style>
        /* Fonte EB Garamond em todos os títulos e parágrafos */
        h1,
        h2,
        h3,
        h4,
        h5,
        h6,
        p,
        .prospect-title,
        .prospect-desc,
        .prospect-feature-text h4,
        .prospect-feature-text p {
            font-family: 'EB Garamond', Georgia, serif !important;
        }
    </style>
    <style>
        .how-section {
            position: relative;
            padding: 100px 24px;
            overflow: hidden;
            background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(4, 4, 5, 0.664), transparent 60%), #09090b;
        }

        .how-section::before {
            content: '';
            position: absolute;
            inset: 0;
            mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black, transparent 75%);
            -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black, transparent 75%);
            pointer-events: none;
        }

        .how-head {
            text-align: center;
            max-width: 640px;
            margin: 0 auto 72px;
            position: relative;
            z-index: 2;
        }

        .how-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.25);
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.2em;
            color: #a5b4fc;
            text-transform: uppercase;
            margin-bottom: 22px;
            font-family: 'Inter', sans-serif;
        }

        .how-title {
            font-family: 'EB Garamond', serif;
            font-size: clamp(34px, 5vw, 54px);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -0.01em;
            margin-bottom: 18px;
            color: var(--accent);
        }

        .how-title .grad {
            background: linear-gradient(120deg, #818cf8, #34D7DD);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .how-sub {
            font-family: 'EB Garamond', serif;
            font-size: 19px;
            line-height: 1.6;
            color: rgba(117, 115, 115, 0.6);
        }

        .how-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            position: relative;
            z-index: 2;
        }

        .step {
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .tilt-card {
            position: relative;
            border-radius: 20px;
            background: linear-gradient(145deg, #15151f, #0d0d16);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 22px;
            aspect-ratio: 4 / 3.2;
            transform-style: preserve-3d;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease;
            will-change: transform;
            overflow: hidden;
            cursor: pointer;
        }

        .tilt-card:hover {
            border-color: rgba(99, 102, 241, 0.35);
        }

        .tilt-glare {
            position: absolute;
            inset: 0;
            border-radius: 20px;
            background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(255, 255, 255, 0.10), transparent 45%);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
            z-index: 5;
        }

        .tilt-card:hover .tilt-glare {
            opacity: 1;
        }

        .step-num {
            position: absolute;
            top: 16px;
            right: 18px;
            font-family: 'EB Garamond', serif;
            font-size: 34px;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.07);
            transform: translateZ(20px);
        }

        .mock {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            transform: translateZ(30px);
        }

        .browser {
            background: #0a0a12;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            overflow: hidden;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .browser-bar {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 8px 10px;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .browser-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
        }

        .browser-body {
            flex: 1;
            padding: 12px;
            position: relative;
        }

        .prompt-box {
            margin: auto 0;
            background: #13131f;
            border: 1px solid rgba(99, 102, 241, 0.3);
            border-radius: 14px;
            padding: 14px;
            transform: translateZ(45px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        }

        .prompt-text {
            font-size: 12.5px;
            color: rgba(239, 236, 241, 0.92);
            line-height: 1.5;
            margin-bottom: 14px;
            font-family: 'Inter', sans-serif;
        }

        .prompt-cursor {
            display: inline-block;
            width: 2px;
            height: 13px;
            background: #818cf8;
            vertical-align: middle;
            margin-left: 1px;
            animation: blink 1s step-end infinite;
        }

        @keyframes blink {
            50% {
                opacity: 0;
            }
        }

        .prompt-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .prompt-tools {
            display: flex;
            gap: 8px;
        }

        .prompt-tool {
            width: 26px;
            height: 26px;
            border-radius: 7px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(241, 245, 249, 0.5);
        }

        .prompt-tool svg {
            width: 13px;
            height: 13px;
        }

        .prompt-send {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            transform: translateZ(15px);
            box-shadow: 0 4px 14px rgba(99, 102, 241, 0.5);
        }

        .prompt-send svg {
            width: 15px;
            height: 15px;
        }

        .prompt-model {
            font-size: 9px;
            font-family: 'JetBrains Mono', monospace;
            color: rgba(241, 245, 249, 0.4);
            padding: 4px 8px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 6px;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .build-hero {
            height: 38%;
            border-radius: 8px;
            background: linear-gradient(120deg, #6366f1, #8b5cf6, #34D7DD);
            margin-bottom: 10px;
            position: relative;
            overflow: hidden;
            transform: translateZ(20px);
        }

        .build-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
            transform: translateX(-100%);
            animation: shimmer 2.2s infinite;
        }

        @keyframes shimmer {
            100% {
                transform: translateX(100%);
            }
        }

        .build-row {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
        }

        .build-block {
            height: 9px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.08);
            animation: pulseBlock 1.8s ease-in-out infinite;
        }

        .build-block.b1 {
            flex: 2;
        }

        .build-block.b2 {
            flex: 1;
        }

        .build-block.b3 {
            flex: 3;
        }

        .build-block.b4 {
            flex: 1.5;
        }

        @keyframes pulseBlock {

            0%,
            100% {
                opacity: 0.4;
            }

            50% {
                opacity: 0.9;
            }
        }

        .build-badge {
            position: absolute;
            bottom: 12px;
            right: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 5px 10px;
            background: rgba(99, 102, 241, 0.18);
            border: 1px solid rgba(99, 102, 241, 0.4);
            border-radius: 20px;
            font-size: 10px;
            color: #a5b4fc;
            font-family: 'Inter', sans-serif;
            transform: translateZ(40px);
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.4);
        }

        .build-badge .spin {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            border: 1.5px solid rgba(165, 180, 252, 0.3);
            border-top-color: #a5b4fc;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }

        .build-cursor {
            position: absolute;
            width: 16px;
            height: 16px;
            top: 55%;
            left: 40%;
            transform: translateZ(50px);
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
            animation: moveCursor 3s ease-in-out infinite;
        }

        @keyframes moveCursor {

            0%,
            100% {
                top: 55%;
                left: 40%;
            }

            50% {
                top: 40%;
                left: 60%;
            }
        }

        .pub-hero {
            height: 34%;
            border-radius: 8px;
            background: linear-gradient(120deg, #34D7DD, #6366f1);
            margin-bottom: 10px;
            transform: translateZ(20px);
        }

        .pub-line {
            height: 8px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.07);
            margin-bottom: 7px;
        }

        .pub-line.l1 {
            width: 70%;
        }

        .pub-line.l2 {
            width: 45%;
        }

        .pub-btn {
            position: absolute;
            top: 46%;
            left: 50%;
            transform: translate(-50%, -50%) translateZ(55px);
            padding: 10px 22px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            font-size: 13px;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            gap: 7px;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.6);
            white-space: nowrap;
        }

        .pub-btn svg {
            width: 14px;
            height: 14px;
        }

        .pub-url {
            position: absolute;
            bottom: 12px;
            left: 12px;
            right: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 11px;
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 8px;
            transform: translateZ(35px);
        }

        .pub-url .live-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #10b981;
            box-shadow: 0 0 8px #10b981;
            animation: pulseLive 1.5s ease-in-out infinite;
        }

        @keyframes pulseLive {
            50% {
                opacity: 0.4;
            }
        }

        .pub-url-text {
            font-size: 10.5px;
            font-family: 'JetBrains Mono', monospace;
            color: #34d399;
        }

        .step-label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 22px 0 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #818cf8;
            font-family: 'Inter', sans-serif;
        }

        .step-label .ln {
            width: 24px;
            height: 1px;
            background: rgba(129, 140, 248, 0.4);
        }

        .step-title {
            font-family: 'EB Garamond', serif;
            font-size: 24px;
            font-weight: 700;
            color: #f1f5f9;
            margin-bottom: 8px;
        }

        .step-desc {
            font-family: 'EB Garamond', serif;
            font-size: 16.5px;
            line-height: 1.55;
            color: rgba(241, 245, 249, 0.55);
        }

        .step:not(:last-child)::after {
            content: '→';
            position: absolute;
            top: 90px;
            right: -22px;
            color: rgba(129, 140, 248, 0.4);
            font-size: 20px;
            z-index: 3;
        }

        @media (max-width: 900px) {
            .how-grid {
                grid-template-columns: 1fr;
                gap: 40px;
                max-width: 440px;
            }

            .step:not(:last-child)::after {
                display: none;
            }

            .tilt-card {
                aspect-ratio: 16 / 10;
            }
        }

        @media (prefers-reduced-motion: reduce) {

            .build-hero::after,
            .build-cursor,
            .build-block,
            .pub-url .live-dot,
            .prompt-cursor {
                animation: none;
            }
        }
    </style>
    <style>
        .brand-logo-icon {
            width: 22px;
            height: 22px;
            object-fit: contain;
            opacity: 0.85;
            transition: opacity 0.3s;
            vertical-align: middle;
        }

        .brand-logo-icon:hover {
            opacity: 1;
        }
    </style>
    <style>
        .comment-avatar-img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            display: block;
        }
    </style>
</head>

<body class="selection:bg-purple-500/30">

    <!-- ATMOSPHERE -->
    <div class="aurora-container">
        <div class="blob w-[50vw] h-[50vh] bg-indigo-900/10 bottom-[-5%] right-[-5%]" style="animation-delay: -5s;">
        </div>
    </div>

    <!-- NAVBAR -->
    <nav class="fixed top-0 w-full z-[100] flex justify-center pt-6 pointer-events-none">
        <div id="topbar" class="pointer-events-auto h-11 topbar px-6 flex items-center space-x-10 rounded-full">
            <div class="hidden md:flex items-center space-x-1 text-[10px] font-bold tracking-[0.2em] uppercase">
                <a href="#hero" class="nav-link">Start</a>
                <a href="#showcase" class="nav-link">Showcase</a>
                <a href="#features" class="nav-link">Features</a>
                <button onclick="toggleModal('login')" class="nav-link">Secure</button>
            </div>
            <button onclick="toggleModal('register')"
                class="join-btn relative inline-flex overflow-hidden rounded-full p-[1px] active:scale-95 transition-all">
                <span class="absolute inset-[-1000%] animate-[spin_2s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#a855f7_0%,#3b82f6_50%,#a855f7_100%)]"></span>
                <span class="inline-flex h-full w-full items-center justify-center rounded-full bg-zinc-950 px-5 py-1.5 text-[10px] font-black tracking-widest uppercase text-white backdrop-blur-3xl hover:bg-zinc-900/90 transition-colors">
                    Join
                </span>
            </button>
        </div>
    </nav>

    <!-- HERO SECTION AAA -->
    <section id="hero"
        class="min-h-[90vh] flex flex-col items-center justify-center px-6 relative pt-16 overflow-hidden"
        style="z-index: 10;">
        <canvas id="dot-grid-canvas"></canvas>

        <div class="reveal text-center space-y-12 relative z-10 w-full">
            <div class="relative flex items-center justify-center">
                <img src="img/Aron-logo.png" alt="Aron Logo"
                    class="h-14 md:h-20 mt-5 mb-5 md:mt-8 md:mb-8 object-contain relative z-10">
            </div>

            <div class="space-y-6">
                <h1 class="text-[10px] font-black tracking-[0.6em] uppercase text-zinc-500/80">Intelligence that
                    Transcends
                </h1>
                <p
                    class="text-4xl md:text-5xl font-black tracking-tighter max-w-4xl mx-auto leading-[1.05] text-[#8A3FFC]">
                    The Future of the Web <br> <span class="text-[#34D7DD]">Engineering and Design.</span>
                </p>

                <p>CRIE SITES E APLICATIVOS COM IA EM SEGUNDOS</p>

                <!-- Virtual Input Simulador -->
                <div class="w-full max-w-3xl mx-auto mt-10 relative">
                    <div
                        class="absolute -top-8 -left-8 w-[220px] h-[220px] bg-[#B349F5]/25 blur-[80px] rounded-full pointer-events-none animate-pulse">
                    </div>
                    <div class="absolute -bottom-8 -right-8 w-[180px] h-[180px] bg-[#34D7DD]/20 blur-[70px] rounded-full pointer-events-none animate-pulse"
                        style="animation-delay:1.2s"></div>
                    <div
                        class="virtual-input-border bg-[rgba(10,10,12,0.7)] backdrop-blur-xl rounded-2xl p-2 flex flex-col shadow-2xl relative z-20">
                        <div
                            class="px-5 py-4 w-full text-left font-sans text-base text-zinc-200 min-h-[70px] flex items-start">
                            <span id="virtual-typing-text"></span><span
                                class="cursor-blink font-light text-[#34D7DD] -ml-1">|</span>
                        </div>
                        <div class="flex items-center justify-between px-2 pb-1 pt-2 w-full border-t border-white/5">
                            <div class="flex items-center space-x-1">
