    </section>
    <style>
        .sc-wrap {
            position: relative;
            padding: 120px 24px 100px;
            background: #09090b;
            overflow: hidden;
            z-index: 5;
        }

        .sc-head {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 80px;
        }

        .sc-eyebrow {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #34D7DD;
            margin-bottom: 18px;
            padding: 6px 14px;
            border: 1px solid rgba(52, 215, 221, 0.25);
            border-radius: 100px;
            background: rgba(52, 215, 221, 0.05);
        }

        .sc-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 700;
            line-height: 1.1;
            color: #fff;
            margin-bottom: 20px;
            letter-spacing: -0.02em;
        }

        .sc-grad {
            background: linear-gradient(120deg, #34D7DD, #8A3FFC 60%, #B349F5);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sc-lead {
            font-size: clamp(0.95rem, 2vw, 1.1rem);
            line-height: 1.7;
            color: #A1A1AA;
            max-width: 560px;
            margin: 0 auto;
        }

        .sc-block {
            display: grid;
            grid-template-columns: 1fr 1.15fr;
            gap: 50px;
            align-items: center;
            max-width: 1080px;
            margin: 0 auto 60px;
            padding: 40px;
            background: linear-gradient(160deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.008));
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 24px;
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

        .sc-block.sc-in {
            opacity: 1;
            transform: translateY(0);
        }

        .sc-reverse .sc-copy {
            order: 2;
        }

        .sc-reverse .sc-mock {
            order: 1;
        }

        .sc-kicker {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--k);
            margin-bottom: 14px;
        }

        .sc-h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(1.4rem, 3vw, 1.9rem);
            font-weight: 600;
            color: #fff;
            margin-bottom: 14px;
            line-height: 1.2;
        }

        .sc-p {
            font-size: 0.95rem;
            line-height: 1.65;
            color: #A1A1AA;
            margin-bottom: 20px;
        }

        .sc-feat {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.88rem;
            color: #d4d4d8;
            margin-bottom: 10px;
        }

        .sc-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .sc-mock {
            width: 100%;
        }

        .sc-browser {
            background: #0d0d10;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
        }

        .sc-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 11px 14px;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .sc-b-dot {
            width: 11px;
            height: 11px;
            border-radius: 50%;
        }

        .sc-url {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: #71717a;
            background: rgba(255, 255, 255, 0.04);
            padding: 4px 16px;
            border-radius: 6px;
        }

        .sc-screen {
            height: 280px;
            padding: 18px;
            position: relative;
            overflow: hidden;
        }

        /* --- Mock SITE --- */
        #mock-site {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .ms-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            opacity: 0;
            transform: translateY(-10px);
        }

        .ms-logo {
            width: 60px;
            height: 14px;
            border-radius: 4px;
            background: linear-gradient(90deg, #34D7DD, #8A3FFC);
        }

        .ms-links {
            display: flex;
            gap: 10px;
        }

        .ms-links i {
            width: 30px;
            height: 8px;
            border-radius: 3px;
            background: rgba(255, 255, 255, 0.15);
        }

        .ms-hero {
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: center;
            margin-top: 12px;
        }

        .ms-h-title {
            width: 70%;
            height: 22px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.22);
            opacity: 0;
            transform: translateY(10px);
        }

        .ms-h-sub {
            width: 50%;
            height: 12px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.1);
            opacity: 0;
            transform: translateY(10px);
        }

        .ms-h-btn {
            width: 100px;
            height: 30px;
            border-radius: 8px;
            background: linear-gradient(90deg, #34D7DD, #8A3FFC);
            opacity: 0;
            transform: translateY(10px);
            margin-top: 4px;
        }

        .ms-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 14px;
        }

        .ms-card {
            height: 60px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            opacity: 0;
            transform: scale(0.9);
        }

        .reveal .ms-nav {
            animation: fadeDown 0.5s 0.1s forwards;
        }

        .reveal .ms-h-title {
            animation: fadeUp 0.5s 0.4s forwards;
        }

        .reveal .ms-h-sub {
            animation: fadeUp 0.5s 0.6s forwards;
        }

        .reveal .ms-h-btn {
            animation: fadeUp 0.5s 0.8s forwards;
        }

        .reveal .ms-card:nth-child(1) {
            animation: popIn 0.4s 1.0s forwards;
        }

        .reveal .ms-card:nth-child(2) {
            animation: popIn 0.4s 1.15s forwards;
        }

        .reveal .ms-card:nth-child(3) {
            animation: popIn 0.4s 1.3s forwards;
        }

        /* --- Mock APP --- */
        #mock-app {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ma-panel {
            width: 100%;
            max-width: 320px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 18px;
        }

        .ma-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .ma-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 14px;
            color: #fff;
            font-weight: 600;
        }

        .ma-badge {
            font-size: 10px;
            font-family: 'JetBrains Mono', monospace;
            color: #10b981;
            background: rgba(16, 185, 129, 0.12);
            padding: 3px 10px;
            border-radius: 100px;
        }

        .ma-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 12px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
            margin-bottom: 8px;
            opacity: 0;
            transform: translateX(-10px);
        }

        .ma-tbl {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: #d4d4d8;
        }

        .ma-count {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: #71717a;
        }

        .ma-foot {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .ma-check {
            font-size: 11px;
            color: #71717a;
            transition: color 0.3s;
        }

        .ma-check.on {
            color: #10b981;
        }

        .reveal .ma-row[data-row="0"] {
            animation: slideIn 0.4s 0.3s forwards;
        }

        .reveal .ma-row[data-row="1"] {
            animation: slideIn 0.4s 0.5s forwards;
        }

        .reveal .ma-row[data-row="2"] {
            animation: slideIn 0.4s 0.7s forwards;
        }

        /* --- Mock DASH --- */
        #mock-dash {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .md-metrics {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }

        .md-metric {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 10px;
            padding: 12px;
        }

        .md-label {
            display: block;
            font-size: 10px;
            color: #71717a;
            margin-bottom: 6px;
            font-family: 'JetBrains Mono', monospace;
        }

        .md-val {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #fff;
        }

        .md-chart {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
            height: 120px;
            padding: 14px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
        }

        .md-bar {
            flex: 1;
            height: 0;
            background: linear-gradient(180deg, #818cf8, #6366f1);
            border-radius: 5px 5px 0 0;
            transition: height 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .reveal .md-bar {
            height: var(--h);
        }

        /* --- Mock GAME --- */
        #mock-game {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
        }

        .mg-score {
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: 'Space Grotesk', sans-serif;
            color: #fff;
            font-size: 14px;
        }

        .mg-pts {
            font-size: 20px;
            font-weight: 700;
            color: #10b981;
        }

        .mg-grid {
            display: grid;
            grid-template-columns: repeat(3, 60px);
            grid-template-rows: repeat(3, 60px);
            gap: 8px;
        }

        .mg-cell {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            font-family: 'Space Grotesk', sans-serif;
        }

        .mg-cell.x {
            color: #34D7DD;
        }

        .mg-cell.o {
            color: #B349F5;
        }

        .mg-cell.win {
            background: rgba(16, 185, 129, 0.15);
            border-color: rgba(16, 185, 129, 0.4);
        }

        @keyframes fadeDown {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes popIn {
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        @keyframes slideIn {
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @media (max-width: 860px) {
            .sc-block {
                grid-template-columns: 1fr;
                gap: 30px;
                padding: 28px;
            }

            .sc-reverse .sc-copy {
                order: 1;
            }

            .sc-reverse .sc-mock {
                order: 2;
            }

            .sc-screen {
                height: 240px;
            }
        }

        @media (max-width: 520px) {
            .sc-wrap {
                padding: 70px 16px 60px;
            }

            .sc-block {
                padding: 20px;
                margin-bottom: 30px;
            }

            .mg-grid {
                grid-template-columns: repeat(3, 48px);
                grid-template-rows: repeat(3, 48px);
            }
        }
    </style>
    <script>
        (function () {
            // Anima contador de 0 ate target
            function animateCount(el, dur) {
                const target = parseInt(el.getAttribute('data-target'), 10);
                const suffix = el.getAttribute('data-suffix') || '';
                const start = performance.now();
                function tick(now) {
                    const p = Math.min((now - start) / dur, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    el.textContent = Math.round(target * eased) + suffix;
                    if (p < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            }

            // Simula jogo da velha jogando sozinho (X vence)
            function playGame(screen) {
                const cells = screen.querySelectorAll('.mg-cell');
                const moves = [
                    { i: 0, p: 'x' }, { i: 4, p: 'o' }, { i: 1, p: 'x' }, { i: 5, p: 'o' }, { i: 2, p: 'x' }
                ];
                cells.forEach(function (c) { c.className = 'mg-cell'; c.textContent = ''; });
                let step = 0;
                function next() {
                    if (step >= moves.length) {
                        // marcar linha vencedora (0,1,2)
                        [0, 1, 2].forEach(function (i) { cells[i].classList.add('win'); });
                        return;
                    }
                    const m = moves[step];
                    cells[m.i].textContent = m.p.toUpperCase();
                    cells[m.i].classList.add(m.p);
                    step++;
                    setTimeout(next, 500);
                }
                setTimeout(next, 400);
            }

            // Ativa a simulacao de um bloco
            function runSim(block) {
                const sim = block.getAttribute('data-sim');
                const screen = block.querySelector('.sc-screen');
                if (!screen) return;

                // Reset e trigger das animacoes CSS (reveal)
                screen.classList.remove('reveal');
                void screen.offsetWidth; // force reflow
                screen.classList.add('reveal');

                if (sim === 'app') {
                    // contadores das tabelas
                    setTimeout(function () {
                        screen.querySelectorAll('.ma-count').forEach(function (c, idx) {
                            setTimeout(function () { animateCount(c, 1000); }, idx * 200);
                        });
                    }, 400);
                    // checks acendem
                    setTimeout(function () {
                        screen.querySelectorAll('.ma-check').forEach(function (ch, idx) {
                            setTimeout(function () {
                                ch.classList.add('on');
                                ch.textContent = ch.textContent.replace('○', '✓');
                            }, idx * 300);
                        });
                    }, 1200);
                    // badge
                    const badge = screen.querySelector('#ma-badge');
                    if (badge) setTimeout(function () { badge.textContent = 'Provisionado'; }, 1800);
                }

                if (sim === 'dash') {
                    setTimeout(function () {
                        screen.querySelectorAll('.md-val').forEach(function (v, idx) {
                            setTimeout(function () { animateCount(v, 1200); }, idx * 150);
                        });
                    }, 300);
                }

                if (sim === 'game') {
                    const pts = screen.querySelector('.mg-pts');
                    playGame(screen);
                    setTimeout(function () { if (pts) animateCount(pts, 600); }, 2600);
                }
            }

            // Loop: re-roda a simulacao a cada X segundos enquanto visivel
            const loops = new Map();
            function startLoop(block) {
                if (loops.has(block)) return;
                runSim(block);
                const id = setInterval(function () { runSim(block); }, 6000);
                loops.set(block, id);
            }
            function stopLoop(block) {
                if (loops.has(block)) { clearInterval(loops.get(block)); loops.delete(block); }
            }

            function boot() {
                const blocks = document.querySelectorAll('#showcase-criar .sc-block');
                const io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) {
                        if (en.isIntersecting) {
                            en.target.classList.add('sc-in');
                            startLoop(en.target);
                        } else {
                            stopLoop(en.target);
                        }
                    });
                }, { threshold: 0.3 });
                blocks.forEach(function (b) { io.observe(b); });
            }

            if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', boot); }
            else { boot(); }
        })();
    </script>
    <!-- ============ FIM SECAO SHOWCASE ============ -->

