        <!-- BLOCO 4: JOGOS -->
        <div class="sc-block sc-reverse" data-sim="game">
            <div class="sc-copy">
                <span class="sc-kicker" style="--k:#10b981">Jogos Interativos</span>
                <h3 class="sc-h3">Lógica de jogo de verdade</h3>
                <p class="sc-p">Jogos com física, pontuação e som reais. Do jogo da velha ao arcade completo — jogáveis
                    de verdade, não só visual.</p>
